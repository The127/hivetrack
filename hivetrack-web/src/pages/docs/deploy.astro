---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  title="Deployment Config Generator — Hivetrack Docs"
  description="Generate a ready-to-use Docker Compose, Docker CLI, or Kubernetes deployment config for Hivetrack."
>
  <div class="flex-1 max-w-5xl mx-auto w-full px-6 py-10">
    <div class="mb-8 space-y-1">
      <h1 class="text-3xl font-semibold text-slate-900 tracking-tight">Deployment config generator</h1>
      <p class="text-slate-500">Fill in the fields and get a ready-to-use config. All generation happens in your browser.</p>
    </div>

    <div id="generator" class="space-y-6">
      <!-- Target tabs -->
      <div class="flex border-b border-slate-200">
        {[
          ['compose', 'Docker Compose'],
          ['docker', 'Docker CLI'],
          ['kubernetes', 'Kubernetes'],
        ].map(([t, label]) => (
          <button
            class="tab-btn px-5 py-2.5 text-sm font-medium transition-colors border-b-2 -mb-px"
            data-target={t}
          >
            {label}
          </button>
        ))}
      </div>

      <!-- Two-column: form + output -->
      <div class="grid lg:grid-cols-2 gap-6">
        <!-- Inputs -->
        <div class="space-y-5">
          <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wider">Configuration</h2>

          <!-- Shared fields -->
          <div class="space-y-4">
            <div class="field">
              <label for="f-version" class="field-label">Image tag / version</label>
              <input id="f-version" type="text" value="latest" class="field-input" data-field="version" />
            </div>
            <div class="field">
              <label for="f-port" class="field-label">Port</label>
              <input id="f-port" type="number" value="8086" class="field-input" data-field="port" />
            </div>
            <div class="field">
              <label for="f-db-url" class="field-label">PostgreSQL URL</label>
              <input id="f-db-url" type="text" placeholder="postgres://hivetrack:secret@postgres:5432/hivetrack?sslmode=disable" class="field-input" data-field="dbUrl" />
            </div>
            <div class="field">
              <label for="f-external-url" class="field-label">External URL</label>
              <input id="f-external-url" type="text" placeholder="https://hivetrack.example.com" class="field-input" data-field="externalUrl" />
            </div>
            <div class="field" id="oidc-authority-field">
              <label for="f-oidc-authority" class="field-label">OIDC Issuer URL</label>
              <input id="f-oidc-authority" type="text" placeholder="https://auth.example.com/realms/my-realm" class="field-input" data-field="oidcAuthority" />
            </div>
            <div class="field" id="oidc-client-id-field">
              <label for="f-oidc-client-id" class="field-label">OIDC Client ID</label>
              <input id="f-oidc-client-id" type="text" placeholder="hivetrack" class="field-input" data-field="oidcClientId" />
            </div>
            <div class="field">
              <label for="f-admin-email" class="field-label">Initial admin email</label>
              <input id="f-admin-email" type="email" placeholder="admin@example.com" class="field-input" data-field="adminEmail" />
            </div>
            <div class="field">
              <label for="f-smtp-host" class="field-label">SMTP host <span class="text-slate-400 font-normal">(optional)</span></label>
              <input id="f-smtp-host" type="text" placeholder="smtp.example.com" class="field-input" data-field="smtpHost" />
            </div>

            <!-- Add-ons -->
            <div class="border-t border-slate-200 pt-4 mt-2 space-y-3">
              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Add-ons</p>
              <label class="flex items-center gap-2 cursor-pointer">
                <input id="f-include-keyline" type="checkbox" class="rounded border-slate-300" />
                <span class="text-sm font-medium text-slate-700">Include Keyline as OIDC provider</span>
                <span class="text-xs text-slate-400">(no existing OIDC? deploy one)</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input id="f-include-mcp" type="checkbox" class="rounded border-slate-300" />
                <span class="text-sm font-medium text-slate-700">Include MCP server</span>
                <span class="text-xs text-slate-400">(AI agent access)</span>
              </label>
            </div>

            <!-- MCP fields -->
            <div id="mcp-fields" class="space-y-4 hidden">
              <div class="field">
                <label for="f-mcp-port" class="field-label">MCP server port</label>
                <input id="f-mcp-port" type="number" value="8080" class="field-input" data-field="mcpPort" />
              </div>
            </div>

            <!-- Keyline fields -->
            <div id="keyline-fields" class="space-y-4 hidden">
              <div class="border-t border-slate-200 pt-4">
                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4">Keyline OIDC provider</p>
                <div class="space-y-4">
                  <div class="field">
                    <label for="f-keyline-api-version" class="field-label">Keyline API image tag</label>
                    <input id="f-keyline-api-version" type="text" value="v0.2.2" class="field-input keyline-input" data-field="keylineApiVersion" />
                  </div>
                  <div class="field">
                    <label for="f-keyline-ui-version" class="field-label">Keyline UI image tag</label>
                    <input id="f-keyline-ui-version" type="text" value="v0.2.2" class="field-input keyline-input" data-field="keylineUiVersion" />
                  </div>
                  <div class="field">
                    <label for="f-keyline-api-port" class="field-label">Keyline API port</label>
                    <input id="f-keyline-api-port" type="number" value="8081" class="field-input keyline-input" data-field="keylineApiPort" />
                  </div>
                  <div class="field">
                    <label for="f-keyline-ui-port" class="field-label">Keyline UI port</label>
                    <input id="f-keyline-ui-port" type="number" value="5177" class="field-input keyline-input" data-field="keylineUiPort" />
                  </div>
                  <div class="field">
                    <label for="f-keyline-external-url" class="field-label">Keyline external URL</label>
                    <input id="f-keyline-external-url" type="text" value="http://localhost:8081" class="field-input keyline-input" data-field="keylineExternalUrl" />
                  </div>
                  <div class="field">
                    <label for="f-keyline-admin-email" class="field-label">Keyline admin email</label>
                    <input id="f-keyline-admin-email" type="email" value="admin@hivetrack.local" class="field-input keyline-input" data-field="keylineAdminEmail" />
                  </div>
                  <div class="field">
                    <label for="f-keyline-virtual-server" class="field-label">Virtual server slug</label>
                    <input id="f-keyline-virtual-server" type="text" value="hivetrack" class="field-input keyline-input" data-field="keylineVirtualServer" />
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Kubernetes-only fields -->
          <div id="k8s-fields" class="space-y-4 hidden">
            <div class="border-t border-slate-200 pt-4">
              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4">Kubernetes options</p>
              <div class="space-y-4">
                <div class="field">
                  <label for="f-namespace" class="field-label">Namespace</label>
                  <input id="f-namespace" type="text" value="hivetrack" class="field-input" data-field="namespace" />
                </div>
                <div class="field">
                  <label for="f-replicas" class="field-label">Replicas</label>
                  <input id="f-replicas" type="number" value="1" min="1" class="field-input" data-field="replicas" />
                </div>
                <div class="field">
                  <label for="f-ingress-host" class="field-label">Ingress hostname <span class="text-slate-400 font-normal">(optional)</span></label>
                  <input id="f-ingress-host" type="text" placeholder="hivetrack.example.com" class="field-input" data-field="ingressHost" />
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Output panels -->
        <div id="output-panels" class="flex flex-col gap-4"></div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .field-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #475569;
    margin-bottom: 0.375rem;
  }
  .field-input {
    width: 100%;
    height: 2rem;
    padding: 0 0.625rem;
    font-size: 0.8125rem;
    color: #1e293b;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .field-input:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgb(59 130 246 / 0.15);
  }
  .field-input::placeholder {
    color: #94a3b8;
  }
  .tab-btn {
    color: #64748b;
    border-color: transparent;
  }
  .tab-btn.active {
    color: #1e293b;
    border-color: #3b82f6;
  }
  .tab-btn:hover:not(.active) {
    color: #334155;
    background: #f8fafc;
  }
</style>

<script>
  type Target = 'compose' | 'docker' | 'kubernetes'

  interface Fields {
    version: string
    port: string
    dbUrl: string
    externalUrl: string
    oidcAuthority: string
    oidcClientId: string
    adminEmail: string
    smtpHost: string
    includeMcp: boolean
    mcpPort: string
    includeKeyline: boolean
    keylineApiVersion: string
    keylineUiVersion: string
    keylineApiPort: string
    keylineUiPort: string
    keylineExternalUrl: string
    keylineAdminEmail: string
    keylineVirtualServer: string
    namespace: string
    replicas: string
    ingressHost: string
  }

  let target: Target = 'compose'

  function getFields(): Fields {
    const get = (id: string) => (document.querySelector<HTMLInputElement>(`[data-field="${id}"]`)?.value ?? '').trim()
    const checked = (id: string) => (document.getElementById(id) as HTMLInputElement)?.checked ?? false
    return {
      version: get('version') || 'latest',
      port: get('port') || '8086',
      dbUrl: get('dbUrl') || 'postgres://hivetrack:secret@postgres:5432/hivetrack?sslmode=disable',
      externalUrl: get('externalUrl') || 'https://hivetrack.example.com',
      oidcAuthority: get('oidcAuthority') || 'https://auth.example.com',
      oidcClientId: get('oidcClientId') || 'hivetrack',
      adminEmail: get('adminEmail') || 'admin@example.com',
      smtpHost: get('smtpHost'),
      includeMcp: checked('f-include-mcp'),
      mcpPort: get('mcpPort') || '8080',
      includeKeyline: checked('f-include-keyline'),
      keylineApiVersion: get('keylineApiVersion') || 'v0.2.2',
      keylineUiVersion: get('keylineUiVersion') || 'v0.2.2',
      keylineApiPort: get('keylineApiPort') || '8081',
      keylineUiPort: get('keylineUiPort') || '5177',
      keylineExternalUrl: get('keylineExternalUrl') || 'http://localhost:8081',
      keylineAdminEmail: get('keylineAdminEmail') || 'admin@hivetrack.local',
      keylineVirtualServer: get('keylineVirtualServer') || 'hivetrack',
      namespace: get('namespace') || 'hivetrack',
      replicas: get('replicas') || '1',
      ingressHost: get('ingressHost'),
    }
  }

  function keylineUiExternalUrl(f: Fields): string {
    try {
      const u = new URL(f.keylineExternalUrl)
      u.port = f.keylineUiPort
      return u.toString().replace(/\/$/, '')
    } catch {
      return `http://localhost:${f.keylineUiPort}`
    }
  }

  function oidcAuthority(f: Fields): string {
    if (f.includeKeyline) return `${f.keylineExternalUrl}/oidc/${f.keylineVirtualServer}`
    return f.oidcAuthority
  }

  function oidcClientId(f: Fields): string {
    if (f.includeKeyline) return 'hivetrack'
    return f.oidcClientId
  }

  // --- Config generators ---

  function generateConfigYaml(f: Fields): string {
    const smtp = f.smtpHost ? `\nemail:\n  smtp_host: ${f.smtpHost}\n  smtp_port: 587` : ''
    return `server:
  host: 0.0.0.0
  port: ${f.port}
  external_url: ${f.externalUrl}
  allowed_origins:
    - ${f.externalUrl}${f.includeKeyline ? `\n    - ${keylineUiExternalUrl(f)}` : ''}

database:
  url: ${f.dbUrl}

oidc:
  authority: ${oidcAuthority(f)}
  client_id: ${oidcClientId(f)}

initial_admin:
  email: ${f.adminEmail}${smtp}`
  }

  function generateKeylineConfig(f: Fields): string {
    const uiUrl = keylineUiExternalUrl(f)
    return `server:
  host: "0.0.0.0"
  port: ${f.keylineApiPort}
  externalUrl: ${f.keylineExternalUrl}
  allowedOrigins:
    - ${uiUrl}
    - ${f.externalUrl}

frontend:
  externalUrl: ${uiUrl}

database:
  mode: postgres
  postgres:
    host: keyline-db
    port: 5432
    username: keyline
    password: secret
    sslMode: disable

keyStore:
  mode: directory
  directory:
    path: ./keys

cache:
  mode: memory

leaderElection:
  mode: none

initialVirtualServer:
  enableRegistration: false
  createAdmin: true
  admin:
    username: admin
    displayName: Admin
    primaryEmail: ${f.keylineAdminEmail}
    # Default password: hivetrack — change before going public
    passwordHash: "\\$argon2id\\$v=19\\$m=16,t=2,p=1\\$MTIzNDU2Nzg\\$QWu7e+sjG5knAdNLoKdLDg"
  projects:
    - slug: ${f.keylineVirtualServer}
      name: Hivetrack
      applications:
        - name: hivetrack
          displayName: Hivetrack
          type: public
          enableDeviceFlow: true
          redirectUris:
            - ${f.externalUrl}/auth/callback
          postLogoutRedirectUris:
            - ${f.externalUrl}/logout-callback`
  }

  function mcpComposeService(f: Fields): string {
    if (!f.includeMcp) return ''
    return `

  hivetrack-mcp:
    image: ghcr.io/the127/hivetrack-mcp:${f.version}
    restart: unless-stopped
    ports:
      - "${f.mcpPort}:8080"
    environment:
      HIVETRACK_URL: http://hivetrack:${f.port}
    depends_on:
      - hivetrack`
  }

  function keylineComposeServices(f: Fields): string {
    if (!f.includeKeyline) return ''
    const uiUrl = keylineUiExternalUrl(f)
    return `

  keyline-db:
    image: postgres:17-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: keyline
      POSTGRES_PASSWORD: secret
      POSTGRES_DB: keyline
    volumes:
      - keyline_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U keyline"]
      interval: 5s
      timeout: 5s
      retries: 10

  keyline-api:
    image: ghcr.io/the127/keyline:${f.keylineApiVersion}
    restart: unless-stopped
    command: ["/app/api", "--config", "/app/config.yml"]
    ports:
      - "${f.keylineApiPort}:${f.keylineApiPort}"
    volumes:
      - ./keyline-config.yaml:/app/config.yml
      - keyline_keys:/app/keys
    depends_on:
      keyline-db:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:${f.keylineApiPort}/health || exit 1"]
      interval: 5s
      timeout: 5s
      retries: 10

  keyline-ui:
    image: ghcr.io/the127/keyline-ui:${f.keylineUiVersion}
    restart: unless-stopped
    ports:
      - "${f.keylineUiPort}:80"
    environment:
      KEYLINE_API_URL: "${f.keylineExternalUrl}"
      KEYLINE_HOST: "${uiUrl}"
    depends_on:
      - keyline-api`
  }

  function generateCompose(f: Fields): string {
    const keylineDep = f.includeKeyline ? `\n      keyline-api:\n        condition: service_healthy` : ''
    const extraVolumes = f.includeKeyline ? `\n  keyline_data:\n  keyline_keys:` : ''
    return `services:
  postgres:
    image: postgres:17-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: hivetrack
      POSTGRES_PASSWORD: secret
      POSTGRES_DB: hivetrack
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U hivetrack"]
      interval: 5s
      timeout: 5s
      retries: 10

  hivetrack:
    image: ghcr.io/the127/hivetrack:${f.version}
    restart: unless-stopped
    ports:
      - "${f.port}:${f.port}"
    volumes:
      - ./config.yaml:/app/config.yaml
    depends_on:
      postgres:
        condition: service_healthy${keylineDep}${keylineComposeServices(f)}${mcpComposeService(f)}

volumes:
  postgres_data:${extraVolumes}`
  }

  function generateDocker(f: Fields): string {
    const mcp = f.includeMcp ? `

# MCP server (AI agent access — pass-through OIDC auth)
docker run -d \\
  --name hivetrack-mcp \\
  --restart unless-stopped \\
  -p ${f.mcpPort}:8080 \\
  -e HIVETRACK_URL=http://hivetrack:${f.port} \\
  ghcr.io/the127/hivetrack-mcp:${f.version}` : ''

    return `# Create config.yaml (shown below), then run:
docker run -d \\
  --name hivetrack \\
  --restart unless-stopped \\
  -p ${f.port}:${f.port} \\
  -v ./config.yaml:/app/config.yaml \\
  ghcr.io/the127/hivetrack:${f.version}${mcp}${f.includeKeyline ? '\n\n# For Keyline containers, use Docker Compose instead.' : ''}`
  }

  function generateK8s(f: Fields): string {
    const ns = f.namespace
    const ingress = f.ingressHost ? `
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: hivetrack
  namespace: ${ns}
spec:
  rules:
    - host: ${f.ingressHost}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: hivetrack
                port:
                  number: ${f.port}` : ''

    const mcpK8s = f.includeMcp ? `
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: hivetrack-mcp
  namespace: ${ns}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: hivetrack-mcp
  template:
    metadata:
      labels:
        app: hivetrack-mcp
    spec:
      containers:
        - name: hivetrack-mcp
          image: ghcr.io/the127/hivetrack-mcp:${f.version}
          ports:
            - containerPort: 8080
          env:
            - name: HIVETRACK_URL
              value: "http://hivetrack:${f.port}"
---
apiVersion: v1
kind: Service
metadata:
  name: hivetrack-mcp
  namespace: ${ns}
spec:
  selector:
    app: hivetrack-mcp
  ports:
    - port: 8080
      targetPort: 8080` : ''

    return `apiVersion: v1
kind: Namespace
metadata:
  name: ${ns}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: hivetrack-config
  namespace: ${ns}
data:
  config.yaml: |
${generateConfigYaml(f).split('\n').map(l => '    ' + l).join('\n')}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: hivetrack
  namespace: ${ns}
spec:
  replicas: ${f.replicas}
  selector:
    matchLabels:
      app: hivetrack
  template:
    metadata:
      labels:
        app: hivetrack
    spec:
      containers:
        - name: hivetrack
          image: ghcr.io/the127/hivetrack:${f.version}
          ports:
            - containerPort: ${f.port}
          volumeMounts:
            - name: config
              mountPath: /app/config.yaml
              subPath: config.yaml
          readinessProbe:
            httpGet:
              path: /api/v1/auth/oidc-config
              port: ${f.port}
            initialDelaySeconds: 5
            periodSeconds: 10
      volumes:
        - name: config
          configMap:
            name: hivetrack-config
---
apiVersion: v1
kind: Service
metadata:
  name: hivetrack
  namespace: ${ns}
spec:
  selector:
    app: hivetrack
  ports:
    - port: ${f.port}
      targetPort: ${f.port}${ingress}${mcpK8s}${f.includeKeyline ? '\n\n# For Keyline on Kubernetes, create a separate namespace with its own ConfigMap and Deployment.' : ''}`
  }

  // --- Output rendering ---

  interface OutputFile {
    label: string
    content: string
    filename: string
  }

  function getOutputFiles(f: Fields): OutputFile[] {
    const files: OutputFile[] = []

    if (target === 'compose') {
      files.push({ label: 'docker-compose.yml', content: generateCompose(f), filename: 'docker-compose.yml' })
      files.push({ label: 'config.yaml', content: generateConfigYaml(f), filename: 'config.yaml' })
    } else if (target === 'docker') {
      files.push({ label: 'docker run', content: generateDocker(f), filename: 'run-hivetrack.sh' })
      files.push({ label: 'config.yaml', content: generateConfigYaml(f), filename: 'config.yaml' })
    } else {
      files.push({ label: 'hivetrack-k8s.yml', content: generateK8s(f), filename: 'hivetrack-k8s.yml' })
    }

    if (f.includeKeyline) {
      files.push({ label: 'keyline-config.yaml', content: generateKeylineConfig(f), filename: 'keyline-config.yaml' })
    }

    return files
  }

  const copyIcon = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>`
  const downloadIcon = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>`

  function render() {
    const f = getFields()
    const files = getOutputFiles(f)
    const container = document.getElementById('output-panels')!
    container.innerHTML = ''

    for (const file of files) {
      const panel = document.createElement('div')
      panel.className = 'flex flex-col'
      panel.innerHTML = `
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">${file.label}</span>
          <div class="flex gap-2">
            <button class="copy-file-btn text-xs text-slate-500 hover:text-slate-900 border border-slate-200 hover:border-slate-300 px-3 py-1.5 rounded-md transition-colors flex items-center gap-1.5">
              ${copyIcon} Copy
            </button>
            <button class="download-file-btn text-xs text-slate-500 hover:text-slate-900 border border-slate-200 hover:border-slate-300 px-3 py-1.5 rounded-md transition-colors flex items-center gap-1.5">
              ${downloadIcon} Download
            </button>
          </div>
        </div>
        <pre class="bg-slate-900 text-slate-100 rounded-lg p-4 text-xs font-mono leading-relaxed overflow-auto min-h-[10rem] whitespace-pre"></pre>
      `
      const pre = panel.querySelector('pre')!
      pre.textContent = file.content

      panel.querySelector('.copy-file-btn')!.addEventListener('click', async (e) => {
        const btn = e.currentTarget as HTMLButtonElement
        await navigator.clipboard.writeText(file.content)
        const orig = btn.innerHTML
        btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!`
        btn.classList.add('text-emerald-600')
        setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('text-emerald-600') }, 2000)
      })

      panel.querySelector('.download-file-btn')!.addEventListener('click', () => {
        const blob = new Blob([file.content], { type: 'text/plain' })
        const a = document.createElement('a')
        a.href = URL.createObjectURL(blob)
        a.download = file.filename
        a.click()
        URL.revokeObjectURL(a.href)
      })

      container.appendChild(panel)
    }
  }

  function syncKeylineOidc() {
    const f = getFields()
    const authorityInput = document.querySelector<HTMLInputElement>('[data-field="oidcAuthority"]')
    const clientIdInput = document.querySelector<HTMLInputElement>('[data-field="oidcClientId"]')
    if (f.includeKeyline) {
      if (authorityInput) {
        authorityInput.value = `${f.keylineExternalUrl}/oidc/${f.keylineVirtualServer}`
        authorityInput.disabled = true
        authorityInput.classList.add('opacity-50')
      }
      if (clientIdInput) {
        clientIdInput.value = 'hivetrack'
        clientIdInput.disabled = true
        clientIdInput.classList.add('opacity-50')
      }
    } else {
      if (authorityInput) { authorityInput.disabled = false; authorityInput.classList.remove('opacity-50') }
      if (clientIdInput) { clientIdInput.disabled = false; clientIdInput.classList.remove('opacity-50') }
    }
  }

  // Tab switching
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn')
  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      target = btn.dataset.target as Target
      tabs.forEach(t => t.classList.remove('active'))
      btn.classList.add('active')
      document.getElementById('k8s-fields')!.classList.toggle('hidden', target !== 'kubernetes')
      render()
    })
  })
  tabs[0]?.classList.add('active')

  // Live update on input
  document.querySelectorAll<HTMLInputElement>('.field-input').forEach(input => {
    input.addEventListener('input', render)
  })

  // Keyline checkbox toggle
  document.getElementById('f-include-keyline')?.addEventListener('change', () => {
    const checked = (document.getElementById('f-include-keyline') as HTMLInputElement).checked
    document.getElementById('keyline-fields')!.classList.toggle('hidden', !checked)
    syncKeylineOidc()
    render()
  })

  // Sync OIDC when keyline fields change
  document.querySelectorAll<HTMLInputElement>('.keyline-input').forEach(input => {
    input.addEventListener('input', () => { syncKeylineOidc(); render() })
  })

  // MCP checkbox toggle
  document.getElementById('f-include-mcp')?.addEventListener('change', () => {
    const checked = (document.getElementById('f-include-mcp') as HTMLInputElement).checked
    document.getElementById('mcp-fields')!.classList.toggle('hidden', !checked)
    render()
  })

  // Initial render
  render()
</script>

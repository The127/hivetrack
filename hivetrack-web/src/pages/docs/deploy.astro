---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  title="Deployment Config Generator — Hivetrack Docs"
  description="Generate a ready-to-use Docker Compose, Docker CLI, or Kubernetes deployment config for Hivetrack."
>
  <div class="flex-1 max-w-5xl mx-auto w-full px-6 py-10">
    <div class="mb-8 space-y-1">
      <h1 class="text-3xl font-semibold text-slate-900 tracking-tight">Deployment config generator</h1>
      <p class="text-slate-500">Fill in the fields and get a ready-to-use config. All generation happens in your browser.</p>
    </div>

    <div id="generator" class="space-y-6">
      <!-- Target tabs -->
      <div class="flex border-b border-slate-200">
        {[
          ['compose', 'Docker Compose'],
          ['docker', 'Docker CLI'],
          ['kubernetes', 'Kubernetes'],
          ['keyline', 'Compose + Keyline'],
        ].map(([t, label]) => (
          <button
            class="tab-btn px-5 py-2.5 text-sm font-medium transition-colors border-b-2 -mb-px"
            data-target={t}
          >
            {label}
          </button>
        ))}
      </div>

      <!-- Two-column: form + output -->
      <div class="grid lg:grid-cols-2 gap-6">
        <!-- Inputs -->
        <div class="space-y-5">
          <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wider">Configuration</h2>

          <!-- Shared fields -->
          <div class="space-y-4">
            <div class="field">
              <label for="f-version" class="field-label">Image tag / version</label>
              <input id="f-version" type="text" value="latest" class="field-input" data-field="version" />
            </div>
            <div class="field">
              <label for="f-port" class="field-label">Port</label>
              <input id="f-port" type="number" value="8086" class="field-input" data-field="port" />
            </div>
            <div class="field">
              <label for="f-db-url" class="field-label">PostgreSQL URL</label>
              <input id="f-db-url" type="text" placeholder="postgres://hivetrack:secret@db:5432/hivetrack" class="field-input" data-field="dbUrl" />
            </div>
            <div class="field">
              <label for="f-external-url" class="field-label">External URL</label>
              <input id="f-external-url" type="text" placeholder="https://hivetrack.example.com" class="field-input" data-field="externalUrl" />
            </div>
            <div class="field">
              <label for="f-oidc-authority" class="field-label">OIDC Issuer URL</label>
              <input id="f-oidc-authority" type="text" placeholder="https://auth.example.com/realms/my-realm" class="field-input" data-field="oidcAuthority" />
            </div>
            <div class="field">
              <label for="f-oidc-client-id" class="field-label">OIDC Client ID</label>
              <input id="f-oidc-client-id" type="text" placeholder="hivetrack" class="field-input" data-field="oidcClientId" />
            </div>
            <div class="field">
              <label for="f-oidc-client-secret" class="field-label">OIDC Client Secret <span class="text-slate-400 font-normal">(optional)</span></label>
              <input id="f-oidc-client-secret" type="text" placeholder="leave blank if using PKCE only" class="field-input" data-field="oidcClientSecret" />
            </div>
            <div class="field">
              <label for="f-admin-email" class="field-label">Initial admin email</label>
              <input id="f-admin-email" type="email" placeholder="admin@example.com" class="field-input" data-field="adminEmail" />
            </div>
            <div class="field">
              <label for="f-smtp-host" class="field-label">SMTP host <span class="text-slate-400 font-normal">(optional)</span></label>
              <input id="f-smtp-host" type="text" placeholder="smtp.example.com" class="field-input" data-field="smtpHost" />
            </div>
          </div>

          <!-- Kubernetes-only fields -->
          <div id="k8s-fields" class="space-y-4 hidden">
            <div class="border-t border-slate-200 pt-4">
              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4">Kubernetes options</p>
              <div class="space-y-4">
                <div class="field">
                  <label for="f-namespace" class="field-label">Namespace</label>
                  <input id="f-namespace" type="text" value="hivetrack" class="field-input" data-field="namespace" />
                </div>
                <div class="field">
                  <label for="f-replicas" class="field-label">Replicas</label>
                  <input id="f-replicas" type="number" value="1" min="1" class="field-input" data-field="replicas" />
                </div>
                <div class="field">
                  <label for="f-ingress-host" class="field-label">Ingress hostname <span class="text-slate-400 font-normal">(optional)</span></label>
                  <input id="f-ingress-host" type="text" placeholder="hivetrack.example.com" class="field-input" data-field="ingressHost" />
                </div>
                <div class="field">
                  <label for="f-storage-class" class="field-label">StorageClass for PVC <span class="text-slate-400 font-normal">(optional)</span></label>
                  <input id="f-storage-class" type="text" placeholder="standard" class="field-input" data-field="storageClass" />
                </div>
              </div>
            </div>
          </div>

          <!-- Keyline-only fields -->
          <div id="keyline-fields" class="space-y-4 hidden">
            <div class="border-t border-slate-200 pt-4">
              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4">Keyline OIDC provider</p>
              <div class="space-y-4">
                <div class="field">
                  <label for="f-keyline-api-version" class="field-label">Keyline API image tag</label>
                  <input id="f-keyline-api-version" type="text" value="latest" class="field-input keyline-input" data-field="keylineApiVersion" />
                </div>
                <div class="field">
                  <label for="f-keyline-ui-version" class="field-label">Keyline UI image tag</label>
                  <input id="f-keyline-ui-version" type="text" value="latest" class="field-input keyline-input" data-field="keylineUiVersion" />
                </div>
                <div class="field">
                  <label for="f-keyline-api-port" class="field-label">Keyline API port</label>
                  <input id="f-keyline-api-port" type="number" value="8081" class="field-input keyline-input" data-field="keylineApiPort" />
                </div>
                <div class="field">
                  <label for="f-keyline-ui-port" class="field-label">Keyline UI port</label>
                  <input id="f-keyline-ui-port" type="number" value="5177" class="field-input keyline-input" data-field="keylineUiPort" />
                </div>
                <div class="field">
                  <label for="f-keyline-external-url" class="field-label">Keyline external URL</label>
                  <input id="f-keyline-external-url" type="text" value="http://localhost:8081" class="field-input keyline-input" data-field="keylineExternalUrl" />
                </div>
                <div class="field">
                  <label for="f-keyline-admin-email" class="field-label">Keyline admin email</label>
                  <input id="f-keyline-admin-email" type="email" value="admin@hivetrack.local" class="field-input keyline-input" data-field="keylineAdminEmail" />
                </div>
                <div class="field">
                  <label for="f-keyline-virtual-server" class="field-label">Virtual server slug</label>
                  <input id="f-keyline-virtual-server" type="text" value="hivetrack" class="field-input keyline-input" data-field="keylineVirtualServer" />
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Output: single panel (compose / docker / k8s) -->
        <div id="output-single" class="flex flex-col">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-sm font-semibold text-slate-700 uppercase tracking-wider">Output</h2>
            <div class="flex gap-2">
              <button
                id="copy-btn"
                class="text-xs text-slate-500 hover:text-slate-900 border border-slate-200 hover:border-slate-300 px-3 py-1.5 rounded-md transition-colors flex items-center gap-1.5"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                Copy
              </button>
              <button
                id="download-btn"
                class="text-xs text-slate-500 hover:text-slate-900 border border-slate-200 hover:border-slate-300 px-3 py-1.5 rounded-md transition-colors flex items-center gap-1.5"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                Download
              </button>
            </div>
          </div>
          <pre id="output" class="flex-1 bg-slate-900 text-slate-100 rounded-lg p-4 text-xs font-mono leading-relaxed overflow-auto min-h-[28rem] whitespace-pre"></pre>
        </div>

        <!-- Output: dual panel (keyline) -->
        <div id="output-keyline" class="hidden flex flex-col gap-4">
          <div class="flex flex-col">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">docker-compose.yml</span>
              <div class="flex gap-2">
                <button
                  id="copy-compose-btn"
                  class="text-xs text-slate-500 hover:text-slate-900 border border-slate-200 hover:border-slate-300 px-3 py-1.5 rounded-md transition-colors flex items-center gap-1.5"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                  Copy
                </button>
                <button
                  id="download-compose-btn"
                  class="text-xs text-slate-500 hover:text-slate-900 border border-slate-200 hover:border-slate-300 px-3 py-1.5 rounded-md transition-colors flex items-center gap-1.5"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                  Download
                </button>
              </div>
            </div>
            <pre id="output-compose" class="bg-slate-900 text-slate-100 rounded-lg p-4 text-xs font-mono leading-relaxed overflow-auto min-h-[14rem] whitespace-pre"></pre>
          </div>
          <div class="flex flex-col">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">keyline-config.yaml</span>
              <div class="flex gap-2">
                <button
                  id="copy-keyline-btn"
                  class="text-xs text-slate-500 hover:text-slate-900 border border-slate-200 hover:border-slate-300 px-3 py-1.5 rounded-md transition-colors flex items-center gap-1.5"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                  Copy
                </button>
                <button
                  id="download-keyline-btn"
                  class="text-xs text-slate-500 hover:text-slate-900 border border-slate-200 hover:border-slate-300 px-3 py-1.5 rounded-md transition-colors flex items-center gap-1.5"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                  Download
                </button>
              </div>
            </div>
            <pre id="output-keyline-config" class="bg-slate-900 text-slate-100 rounded-lg p-4 text-xs font-mono leading-relaxed overflow-auto min-h-[14rem] whitespace-pre"></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .field-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #475569;
    margin-bottom: 0.375rem;
  }
  .field-input {
    width: 100%;
    height: 2rem;
    padding: 0 0.625rem;
    font-size: 0.8125rem;
    color: #1e293b;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .field-input:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgb(59 130 246 / 0.15);
  }
  .field-input::placeholder {
    color: #94a3b8;
  }
  .tab-btn {
    color: #64748b;
    border-color: transparent;
  }
  .tab-btn.active {
    color: #1e293b;
    border-color: #3b82f6;
  }
  .tab-btn:hover:not(.active) {
    color: #334155;
    background: #f8fafc;
  }
</style>

<script>
  type Target = 'compose' | 'docker' | 'kubernetes' | 'keyline'

  interface Fields {
    version: string
    port: string
    dbUrl: string
    externalUrl: string
    oidcAuthority: string
    oidcClientId: string
    oidcClientSecret: string
    adminEmail: string
    smtpHost: string
    namespace: string
    replicas: string
    ingressHost: string
    storageClass: string
    keylineApiVersion: string
    keylineUiVersion: string
    keylineApiPort: string
    keylineUiPort: string
    keylineExternalUrl: string
    keylineAdminEmail: string
    keylineVirtualServer: string
  }

  let target: Target = 'compose'

  function getFields(): Fields {
    const get = (id: string) => (document.querySelector<HTMLInputElement>(`[data-field="${id}"]`)?.value ?? '').trim()
    return {
      version: get('version') || 'latest',
      port: get('port') || '8086',
      dbUrl: get('dbUrl') || 'postgres://hivetrack:secret@db:5432/hivetrack?sslmode=disable',
      externalUrl: get('externalUrl') || 'https://hivetrack.example.com',
      oidcAuthority: get('oidcAuthority') || 'https://auth.example.com',
      oidcClientId: get('oidcClientId') || 'hivetrack',
      oidcClientSecret: get('oidcClientSecret'),
      adminEmail: get('adminEmail') || 'admin@example.com',
      smtpHost: get('smtpHost'),
      namespace: get('namespace') || 'hivetrack',
      replicas: get('replicas') || '1',
      ingressHost: get('ingressHost'),
      storageClass: get('storageClass'),
      keylineApiVersion: get('keylineApiVersion') || 'latest',
      keylineUiVersion: get('keylineUiVersion') || 'latest',
      keylineApiPort: get('keylineApiPort') || '8081',
      keylineUiPort: get('keylineUiPort') || '5177',
      keylineExternalUrl: get('keylineExternalUrl') || 'http://localhost:8081',
      keylineAdminEmail: get('keylineAdminEmail') || 'admin@hivetrack.local',
      keylineVirtualServer: get('keylineVirtualServer') || 'hivetrack',
    }
  }

  function keylineUiExternalUrl(f: Fields): string {
    try {
      const u = new URL(f.keylineExternalUrl)
      u.port = f.keylineUiPort
      return u.toString().replace(/\/$/, '')
    } catch {
      return `http://localhost:${f.keylineUiPort}`
    }
  }

  function generateConfigYaml(f: Fields): string {
    const smtp = f.smtpHost ? `\nemail:\n  smtp_host: ${f.smtpHost}\n  smtp_port: 587` : ''
    return `server:
  host: 0.0.0.0
  port: ${f.port}
  external_url: ${f.externalUrl}
  allowed_origins:
    - ${f.externalUrl}

database:
  url: ${f.dbUrl}

oidc:
  authority: ${f.oidcAuthority}
  client_id: ${f.oidcClientId}

initial_admin:
  email: ${f.adminEmail}${smtp}`
  }

  function generateCompose(f: Fields): string {
    return `services:
  postgres:
    image: postgres:17-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: hivetrack
      POSTGRES_PASSWORD: secret
      POSTGRES_DB: hivetrack
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U hivetrack"]
      interval: 5s
      timeout: 5s
      retries: 10

  hivetrack:
    image: ghcr.io/the127/hivetrack:${f.version}
    restart: unless-stopped
    ports:
      - "${f.port}:${f.port}"
    volumes:
      - ./config.yaml:/app/config.yaml
    depends_on:
      postgres:
        condition: service_healthy

volumes:
  postgres_data:

# Save the config.yaml shown below alongside this file.`
  }

  function generateKeylineCompose(f: Fields): string {
    const uiUrl = keylineUiExternalUrl(f)
    return `services:
  postgres:
    image: postgres:17-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: hivetrack
      POSTGRES_PASSWORD: secret
      POSTGRES_DB: hivetrack
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U hivetrack"]
      interval: 5s
      timeout: 5s
      retries: 10

  hivetrack:
    image: ghcr.io/the127/hivetrack:${f.version}
    restart: unless-stopped
    ports:
      - "${f.port}:${f.port}"
    volumes:
      - ./config.yaml:/app/config.yaml
    depends_on:
      postgres:
        condition: service_healthy
      keyline-api:
        condition: service_healthy

  keyline-db:
    image: postgres:17-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: keyline
      POSTGRES_PASSWORD: secret
      POSTGRES_DB: keyline
    volumes:
      - keyline_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U keyline"]
      interval: 5s
      timeout: 5s
      retries: 10

  keyline-api:
    image: ghcr.io/the127/keyline:${f.keylineApiVersion}
    restart: unless-stopped
    ports:
      - "${f.keylineApiPort}:${f.keylineApiPort}"
    volumes:
      - ./keyline-config.yaml:/app/config.yaml
    depends_on:
      keyline-db:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:${f.keylineApiPort}/health || exit 1"]
      interval: 5s
      timeout: 5s
      retries: 10

  keyline-ui:
    image: ghcr.io/the127/keyline-ui:${f.keylineUiVersion}
    restart: unless-stopped
    ports:
      - "${f.keylineUiPort}:${f.keylineUiPort}"
    environment:
      KEYLINE_API_URL: "${f.keylineExternalUrl}"
    depends_on:
      - keyline-api

volumes:
  postgres_data:
  keyline_data:`
  }

  function generateKeylineConfig(f: Fields): string {
    const uiUrl = keylineUiExternalUrl(f)
    const hivetrackUrl = f.externalUrl || 'https://hivetrack.example.com'
    return `server:
  host: 0.0.0.0
  port: ${f.keylineApiPort}
  externalUrl: ${f.keylineExternalUrl}
  allowedOrigins:
    - ${uiUrl}
    - ${hivetrackUrl}

frontend:
  externalUrl: ${uiUrl}

database:
  url: postgres://keyline:secret@keyline-db:5432/keyline?sslmode=disable

keyStore:
  # Keyline generates a signing key on first start.
  # Set this explicitly for multi-replica or persistent key stability.
  signingKey: ""

cache:
  type: memory

leaderElection:
  enabled: false

initialVirtualServer:
  slug: ${f.keylineVirtualServer}
  name: Hivetrack
  admin:
    email: ${f.keylineAdminEmail}
    # Default password: hivetrack — change before going public
    passwordHash: "$2y$12$oOOVAx6u2cZtS0ZqHb4aBurii/qMAAvFxSLmGgzcvbs0SxghjG5dm"
  application:
    clientId: hivetrack
    name: Hivetrack
    redirectUris:
      - ${hivetrackUrl}/oidc/callback
      - ${hivetrackUrl}`
  }

  function generateDocker(f: Fields): string {
    return `# First create config.yaml (see config tab below), then:
docker run -d \\
  --name hivetrack \\
  --restart unless-stopped \\
  -p ${f.port}:${f.port} \\
  -v ./config.yaml:/app/config.yaml \\
  ghcr.io/the127/hivetrack:${f.version}`
  }

  function generateK8s(f: Fields): string {
    const ns = f.namespace
    const ingress = f.ingressHost ? `
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: hivetrack
  namespace: ${ns}
spec:
  rules:
    - host: ${f.ingressHost}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: hivetrack
                port:
                  number: ${f.port}` : ''

    return `apiVersion: v1
kind: Namespace
metadata:
  name: ${ns}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: hivetrack-config
  namespace: ${ns}
data:
  config.yaml: |
${generateConfigYaml(f).split('\n').map(l => '    ' + l).join('\n')}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: hivetrack
  namespace: ${ns}
spec:
  replicas: ${f.replicas}
  selector:
    matchLabels:
      app: hivetrack
  template:
    metadata:
      labels:
        app: hivetrack
    spec:
      containers:
        - name: hivetrack
          image: ghcr.io/the127/hivetrack:${f.version}
          ports:
            - containerPort: ${f.port}
          volumeMounts:
            - name: config
              mountPath: /app/config.yaml
              subPath: config.yaml
          readinessProbe:
            httpGet:
              path: /api/v1/auth/oidc-config
              port: ${f.port}
            initialDelaySeconds: 5
            periodSeconds: 10
      volumes:
        - name: config
          configMap:
            name: hivetrack-config
---
apiVersion: v1
kind: Service
metadata:
  name: hivetrack
  namespace: ${ns}
spec:
  selector:
    app: hivetrack
  ports:
    - port: ${f.port}
      targetPort: ${f.port}${ingress}`
  }

  function render() {
    const f = getFields()
    const singlePanel = document.getElementById('output-single')!
    const keylinePanel = document.getElementById('output-keyline')!

    if (target === 'keyline') {
      singlePanel.classList.add('hidden')
      keylinePanel.classList.remove('hidden')
      document.getElementById('output-compose')!.textContent = generateKeylineCompose(f)
      document.getElementById('output-keyline-config')!.textContent = generateKeylineConfig(f)
    } else if (target === 'kubernetes') {
      // K8s embeds config in ConfigMap, single panel is enough
      singlePanel.classList.remove('hidden')
      keylinePanel.classList.add('hidden')
      document.getElementById('output')!.textContent = generateK8s(f)
    } else {
      // Compose and Docker need two panels: the main output + config.yaml
      singlePanel.classList.add('hidden')
      keylinePanel.classList.remove('hidden')
      const mainLabel = target === 'compose' ? 'docker-compose.yml' : 'docker run'
      document.querySelector('#output-keyline .flex:first-child .text-xs.font-semibold')!.textContent = mainLabel
      document.querySelector('#output-keyline .flex:last-child .text-xs.font-semibold')!.textContent = 'config.yaml'
      document.getElementById('output-compose')!.textContent =
        target === 'compose' ? generateCompose(f) : generateDocker(f)
      document.getElementById('output-keyline-config')!.textContent = generateConfigYaml(f)
    }
  }

  function syncOidcAuthority() {
    if (target !== 'keyline') return
    const f = getFields()
    const input = document.querySelector<HTMLInputElement>('[data-field="oidcAuthority"]')
    if (input) input.value = `${f.keylineExternalUrl}/oidc/${f.keylineVirtualServer}`
  }

  // Tab switching
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn')
  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      target = btn.dataset.target as Target
      tabs.forEach(t => t.classList.remove('active'))
      btn.classList.add('active')
      document.getElementById('k8s-fields')!.classList.toggle('hidden', target !== 'kubernetes')
      document.getElementById('keyline-fields')!.classList.toggle('hidden', target !== 'keyline')
      if (target === 'keyline') syncOidcAuthority()
      render()
    })
  })
  // Activate first tab
  tabs[0]?.classList.add('active')

  // Live update on input
  document.querySelectorAll<HTMLInputElement>('.field-input').forEach(input => {
    input.addEventListener('input', render)
  })

  // Sync OIDC authority when keyline fields change
  document.querySelectorAll<HTMLInputElement>('.keyline-input').forEach(input => {
    input.addEventListener('input', syncOidcAuthority)
  })

  // Copy (single)
  document.getElementById('copy-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('copy-btn')!
    await navigator.clipboard.writeText(document.getElementById('output')!.textContent ?? '')
    const orig = btn.innerHTML
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!`
    btn.classList.add('text-emerald-600')
    setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('text-emerald-600') }, 2000)
  })

  // Download (single)
  document.getElementById('download-btn')?.addEventListener('click', () => {
    const ext = target === 'docker' ? 'sh' : 'yml'
    const name = target === 'kubernetes' ? `hivetrack-k8s.${ext}` : target === 'docker' ? `run-hivetrack.${ext}` : `docker-compose.${ext}`
    const blob = new Blob([document.getElementById('output')!.textContent ?? ''], { type: 'text/plain' })
    const a = document.createElement('a')
    a.href = URL.createObjectURL(blob)
    a.download = name
    a.click()
    URL.revokeObjectURL(a.href)
  })

  // Copy compose (keyline)
  document.getElementById('copy-compose-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('copy-compose-btn')!
    await navigator.clipboard.writeText(document.getElementById('output-compose')!.textContent ?? '')
    const orig = btn.innerHTML
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!`
    btn.classList.add('text-emerald-600')
    setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('text-emerald-600') }, 2000)
  })

  // Download compose (keyline)
  document.getElementById('download-compose-btn')?.addEventListener('click', () => {
    const blob = new Blob([document.getElementById('output-compose')!.textContent ?? ''], { type: 'text/plain' })
    const a = document.createElement('a')
    a.href = URL.createObjectURL(blob)
    a.download = 'docker-compose.yml'
    a.click()
    URL.revokeObjectURL(a.href)
  })

  // Copy keyline config
  document.getElementById('copy-keyline-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('copy-keyline-btn')!
    await navigator.clipboard.writeText(document.getElementById('output-keyline-config')!.textContent ?? '')
    const orig = btn.innerHTML
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!`
    btn.classList.add('text-emerald-600')
    setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('text-emerald-600') }, 2000)
  })

  // Download keyline config
  document.getElementById('download-keyline-btn')?.addEventListener('click', () => {
    const blob = new Blob([document.getElementById('output-keyline-config')!.textContent ?? ''], { type: 'text/plain' })
    const a = document.createElement('a')
    a.href = URL.createObjectURL(blob)
    a.download = 'keyline-config.yaml'
    a.click()
    URL.revokeObjectURL(a.href)
  })

  // Initial render
  render()
</script>

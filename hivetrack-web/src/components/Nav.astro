---
const links = [
  { label: 'Docs', href: '/docs/getting-started' },
]
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center gap-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 mr-auto">
      <img src="/logo.svg" alt="Hivetrack" width="28" height="28" />
      <span class="font-semibold text-slate-900 tracking-tight">Hivetrack</span>
    </a>

    <!-- Desktop links -->
    <nav class="hidden sm:flex items-center gap-5 text-sm text-slate-500">
      {links.map(l => (
        <a href={l.href} class="hover:text-slate-900 transition-colors">{l.label}</a>
      ))}
      <a
        href="https://github.com/The127/hivetrack"
        target="_blank"
        rel="noopener"
        class="hover:text-slate-900 transition-colors flex items-center gap-1.5"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub
      </a>
    </nav>

    <!-- CTA -->
    <a
      href="/docs/getting-started"
      class="text-sm font-medium bg-blue-600 hover:bg-blue-700 text-white px-4 py-1.5 rounded-md transition-colors"
    >
      Get started
    </a>

    <!-- Mobile menu toggle (no JS needed — links are visible at sm+) -->
    <button
      class="sm:hidden flex flex-col gap-1.5 p-1"
      aria-label="Toggle menu"
      onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
    >
      <span class="w-5 h-0.5 bg-slate-600 block"></span>
      <span class="w-5 h-0.5 bg-slate-600 block"></span>
      <span class="w-5 h-0.5 bg-slate-600 block"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-slate-100 bg-white px-6 py-3 space-y-1">
    {links.map(l => (
      <a href={l.href} class="block py-2 text-sm text-slate-600 hover:text-slate-900 transition-colors">{l.label}</a>
    ))}
    <a
      href="https://github.com/The127/hivetrack"
      target="_blank"
      rel="noopener"
      class="block py-2 text-sm text-slate-600 hover:text-slate-900 transition-colors"
    >
      GitHub
    </a>
  </div>
</header>

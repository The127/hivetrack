# ─── Stage 1: Build ────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder
WORKDIR /build

# Copy client library first (MCP depends on it via replace directive)
COPY client/ ./client/

# Copy MCP module and download dependencies
COPY mcp/go.mod mcp/go.sum ./mcp/
WORKDIR /build/mcp
RUN go mod download
COPY mcp/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -o /hivetrack-mcp ./cmd/hivetrack-mcp

# ─── Stage 2: Runtime ──────────────────────────────────────────────────────
FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=builder /hivetrack-mcp /hivetrack-mcp

# Default to HTTP transport for container deployments.
# The only required env var is HIVETRACK_URL.
# Auth is pass-through: callers provide their own OIDC Bearer token.
ENV HIVETRACK_MCP_TRANSPORT=http
ENV HIVETRACK_MCP_LISTEN=:8080
EXPOSE 8080

ENTRYPOINT ["/hivetrack-mcp"]
